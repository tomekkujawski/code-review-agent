+    public function findByUserAndStatus(string $userId, string $status): array
+    {
+        /** @var Connection $conn */
+        $conn = $this->getEntityManager()->getConnection();
+
+        $sql = "SELECT * FROM `order`"
+            . " WHERE user_id = " . $userId
+            . " AND status = '" . $status . "'";
